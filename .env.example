# Database (para rodar local; no Docker o compose usa POSTGRES_* e host "postgres")
DATABASE_URL="postgresql://user:password@localhost:5432/fique_ryco?schema=public"

# Para Docker deploy: defina no .env (ou use os padrões do docker-compose)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=fique_ryco
# JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# JWT_EXPIRATION=7d
# CORS_ORIGIN=*
# APP_PORT=3000
# POSTGRES_PORT=5432

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION="7d"

# Upload
UPLOAD_DIR="./uploads"

# CORS
CORS_ORIGIN="http://localhost:3001"
