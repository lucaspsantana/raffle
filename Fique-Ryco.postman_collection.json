							"script": {
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set('jwt_token', jsonData.access_token);",
									"    pm.environment.set('admin_id', jsonData.user.id);",
